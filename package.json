{
  "name": "autoflowcut",
  "version": "0.9.10",
  "buildNumber": 517,
  "description": "AutoFlowCut - Automate AI video creation from Google Flow to CapCut projects",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "patch-electron-name": "node scripts/patch-electron-name.cjs",
    "postinstall": "node scripts/patch-electron-name.cjs",
    "predev": "node scripts/patch-electron-name.cjs",
    "dev": "vite",
    "dev:prod": "vite --mode production",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "make-ico": "node scripts/make-ico.cjs",
    "pack": "vite build && electron-builder --dir",
    "dist": "npm run bump:build && vite build --mode production && electron-builder",
    "dist:mac": "npm run bump:build && vite build --mode production && electron-builder --mac",
    "dist:win": "npm run bump:build && vite build --mode production && electron-builder --win",
    "dist:test": "vite build --mode development && electron-builder",
    "dist:test:mac": "vite build --mode development && electron-builder --mac",
    "dist:test:win": "vite build --mode development && electron-builder --win",
    "mcp:install": "cd mcp-server && npm install --omit=dev",
    "bump:build": "node scripts/bump-build.cjs",
    "dist:win:nsis": "npm run bump:build && npm run mcp:install && set VITE_BUILD_TARGET=nsis&& set VITE_FUNCTION_ENV=prod&& vite build --mode production && electron-builder --win nsis",
    "dist:win:appx": "npm run bump:build && npm run mcp:install && set VITE_BUILD_TARGET=appx&& set VITE_FUNCTION_ENV=prod&& vite build --mode production && scripts\\buildappx.bat",
    "dist:win:all": "npm run bump:build && npm run mcp:install && set VITE_FUNCTION_ENV=prod&& vite build --mode production && electron-builder --win",
    "dist:linux": "npm run bump:build && npm run mcp:install && VITE_FUNCTION_ENV=prod vite build --mode production && electron-builder --linux",
    "dist:mac:prod": "npm run bump:build && npm run mcp:install && VITE_FUNCTION_ENV=prod vite build --mode production && electron-builder --mac",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Touchizen",
  "license": "AGPL-3.0-only",
  "private": true,
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "firebase": "^12.9.0",
    "flag-icons": "^7.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^36.9.5",
    "electron-builder": "^26.7.0",
    "jsdom": "^28.1.0",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.touchizen.flow2capcut",
    "productName": "AutoFlowCut",
    "forceCodeSigning": true,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "touchizen",
        "repo": "AutoFlowCut"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "!assets/icon.iconset"
    ],
    "afterPack": "./scripts/afterPack.cjs",
    "extraResources": [
      {
        "from": "mcp-server",
        "to": "mcp-server"
      },
      {
        "from": "docs",
        "to": "docs",
        "filter": [
          "csv-*.md",
          "srt-*.md",
          "audio-*.md",
          "prompt-*.md"
        ]
      },
      {
        "from": "skills",
        "to": "skills"
      },
      {
        "from": "src/config",
        "to": "src/config",
        "filter": [
          "*.json"
        ]
      }
    ],
    "afterSign": "scripts/notarize.cjs",
    "afterAllArtifactBuild": "scripts/notarize-dmg.cjs",
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-win-${arch}.${ext}",
      "signtoolOptions": {
        "certificateSha1": "778FF11A7D92ABBB2DF9998ABDFB6F1200E0C0DF",
        "timeStampServer": "http://time.certum.pl",
        "rfc3161TimeStampServer": "http://time.certum.pl",
        "publisherName": "Open Source Developer Gook Whan Ahn"
      },
      "target": [
        "nsis",
        "zip",
        "appx"
      ]
    },
    "appx": {
      "identityName": "6129CF9F.AutoFlowCut",
      "publisher": "CN=5939ADED-0FF9-4D26-A5D6-928AE9B2B6BC",
      "publisherDisplayName": "Touchizen",
      "languages": [
        "en-US",
        "ko-KR"
      ],
      "applicationId": "AutoFlowCut",
      "displayName": "AutoFlowCut",
      "backgroundColor": "transparent"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-win-${arch}-Setup.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Video",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
